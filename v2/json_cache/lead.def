{
    "def_groups": [
        {
            "frequency": "Extremely Common",
            "gram_groups": [
                {
                    "defs": {
                        "": [
                            {
                                "def": "to show the way to (an individual or a group) by going with or ahead",
                                "example": "lead the party into the garden",
                                "mark": "good"
                            },
                            {
                                "def": "to guide or be guided by holding, pulling, etc",
                                "example": "he led the horse by its reins",
                                "mark": "good"
                            },
                            {
                                "def": "to guide, control, or direct",
                                "example": "to lead an army",
                                "mark": "good"
                            },
                            {
                                "def": "to initiate the action of (something); have the principal part in (something)",
                                "example": "to lead a discussion",
                                "mark": "good"
                            },
                            {
                                "def": "to go at the head of or have the top position in (something)",
                                "example": "he leads his class in geography",
                                "mark": "good"
                            },
                            {
                                "category": "music",
                                "def_subgroup": [
