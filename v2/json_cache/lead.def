                    "defs": {
                        "": [
                            {
                                "def": "a heavy toxic bluish-white metallic element that is highly malleable: occurs principally as galena and used in alloys, accumulators, cable sheaths, paints, and as a radiation shield. Symbol: Pb; atomic no: 82; atomic wt: 207.2; valency: 2 or 4; relative density: 11.35; melting pt: 327.502°C; boiling pt: 1750°C",
                                "mark": "good"
                            },
                            {
                                "def": "a lead weight suspended on a line used to take soundings of the depth of water",
                                "mark": "good"
                            },
                            {
                                "def": "(i) See swing the lead",
                                "mark": "good"
                            },
                            {
                                "def": "lead weights or shot, as used in cartridges, fishing lines, etc",
                                "mark": "good"
                            },
                            {
                                "def": "a thin grooved strip of lead for holding small panes of glass or pieces of stained glass",
                                "mark": "good"
                            },
