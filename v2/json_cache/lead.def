                                "def": "to make an offensive blow, esp as one's habitual attacking punch",
                                "example": "southpaws lead with their right",
                                "mark": "good"
                            }
                        ],
                        "intransitive; foll by to": [
                            {
                                "def": "to tend (to) or result (in)",
                                "example": "this will only lead to misery",
                                "mark": "good"
                            }
                        ],
                        "intransitive; foll by with": [
                            {
                                "def": "to have as the first or principal item",
                                "example": "the newspaper led with the royal birth",
