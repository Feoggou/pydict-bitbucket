                                        "mark": "good"
                                    }
                                ]
                            },
                            {
                                "def": "to direct and guide (one's partner) in a dance",
                                "mark": "good"
                            },
                            {
                                "def": "to initiate a round of cards by putting down (the first card) or to have the right to do this",
                                "example": "she led a diamond",
                                "mark": "good"
                            },
                            {
                                "def": "(i) See lead astray",
                                "mark": "good"
                            },
