                {
                    "defs": {
                        "": [
                            {
                                "def": "characterized by an absence or near absence of noise",
                                "example": "a quiet street",
                                "mark": "good"
                            },
                            {
                                "def": "characterized by an absence of turbulent motion or disturbance; peaceful, calm, or tranquil",
                                "example": "a quiet glade; the sea is quiet tonight",
                                "mark": "good"
                            },
                            {
                                "def": "free from activities, distractions, worries, etc; untroubled",
                                "example": "a quiet life; a quiet day at work",
                                "mark": "good"
                            },
                            {
                                "def": "marked by an absence of work, orders, etc; not busy",
                                "example": "the factory is very quiet at the moment",
                                "mark": "good"
                            },
                            {
                                "def": "private; not public; secret",
                                "example": "a quiet word with someone",
                                "mark": "good"
                            },
                            {
                                "def": "free from anger, impatience, or other extreme emotion",
                                "example": "a quiet disposition",
                                "mark": "good"
                            },
                            {
                                "def": "free from pretentiousness or vain display; modest or reserved",
                                "example": "quiet humour",
                                "mark": "good"
                            },
                            {
                                "category": "astronomy",
                                "def": "(of the sun) exhibiting a very low number of sunspots, solar flares, and other surface phenomena; inactive",
                                "mark": "good"
                            }
                        ]
